# ── Git ignore patterns for OpenWave ──────────────────────────
# NEVER commit real .env files — only .env.example is safe to commit

# Environment files (all apps)
.env
.env.local
.env.production
.env.staging
apps/**/.env
apps/**/.env.local
apps/**/.env.production

# Node
node_modules/
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# TypeScript build info
*.tsbuildinfo

# Vite cache
.vite/
