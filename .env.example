# =============================================================
#  OPENWAVE — ROOT ENVIRONMENT REFERENCE
#  Copy the relevant sections into the correct app's .env file
# =============================================================

# ── BACKEND (apps/backend/.env) ──────────────────────────────

# Express server port
PORT=3001

# Jamendo API — get your Client ID at https://devportal.jamendo.com/
JAMENDO_CLIENT_ID=your_jamendo_client_id_here
JAMENDO_API_BASE=https://api.jamendo.com/v3.0

# Supabase — Project URL and Service Role key
# Found at: https://app.supabase.com/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=your_very_long_random_jwt_secret_here

# Allowed frontend origin (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# ── FRONTEND (apps/frontend/.env) ────────────────────────────

# Backend HTTP URL
VITE_BACKEND_URL=http://localhost:3001

# Backend WebSocket URL
VITE_WS_URL=ws://localhost:3001

# Supabase — same URL as backend
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (SAFE for browser — NOT the service role key)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
