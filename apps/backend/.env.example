# =============================================================
#  OPENWAVE BACKEND — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file to version control.
# =============================================================

# ── SERVER ───────────────────────────────────────────────────
# Port the Express server listens on
PORT=3001

# ── JAMENDO API ──────────────────────────────────────────────
# Register at https://devportal.jamendo.com/ to get a free Client ID
# Free tier: 50,000 API calls/day
JAMENDO_CLIENT_ID=your_jamendo_client_id_here

# Jamendo REST API base URL (do not change unless using a mirror)
JAMENDO_API_BASE=https://api.jamendo.com/v3.0

# ── PIPED API (YOUTUBE PROXY) ────────────────────────────────
# Decentralized proxy to avoid official Google API restrictions
PIPED_API_BASE=https://pipedapi.kavin.rocks

# ── SUPABASE ─────────────────────────────────────────────────
# Your Supabase project URL
# Found at: https://app.supabase.com/project/<ref>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Service Role Key — has admin privileges, NEVER expose to client
# Found at: https://app.supabase.com/project/<ref>/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── JWT ──────────────────────────────────────────────────────
# Random secret for custom JWT signing (if needed beyond Supabase Auth)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_very_long_random_jwt_secret_here

# ── CORS ─────────────────────────────────────────────────────
# Exact frontend origin allowed to connect (no trailing slash)
CORS_ORIGIN=http://localhost:5173
