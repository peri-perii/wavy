# =============================================================
#  OPENWAVE FRONTEND — Environment Variables
#  Copy this file to .env and fill in your values.
#  Only VITE_* variables are bundled into the browser.
#  NEVER put secret keys (service role, JWT) here.
# =============================================================

# ── BACKEND ──────────────────────────────────────────────────
# HTTP base URL of your backend server
VITE_BACKEND_URL=http://localhost:3001

# WebSocket URL of your backend server
VITE_WS_URL=ws://localhost:3001

# ── SUPABASE (PUBLIC VALUES ONLY) ────────────────────────────
# Your Supabase project URL (safe for browser)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — this is safe for the browser
# Found at: https://app.supabase.com/project/<ref>/settings/api
# ⚠️  Do NOT use the service_role key here — it bypasses all row-level security
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
